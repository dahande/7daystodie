<config>
	<!-- === AEC-AIO BOSS === -->

<append xpath="/blocks">
		<block name="aecQuestSignalLure">
			<property name="CustomIcon" value="capChimney"/>
			<property name="DescriptionKey" value="aecQuestSignalLureDesc"/>
			<property name="Material" value="Mmetal_weak"/>
			<property name="MaxDamage" value="15"/>
			<property name="Shape" value="ModelEntity"/>
			<property name="Model" value="@:Entities/Buildings/capChimneyLargeSmokePrefab.prefab"/>
			<property name="DisplayType" value="blockHardened"/>
			<property name="ImposterExchange" value="imposterDontBlockCTRPole" param1="87"/>
			<property name="CustomIconTint" value="FF4500"/>
			<property name="TintColor" value="FF4500"/>
			<property name="WaterFlow" value="permitted"/>
			<property name="EconomicValue" value="20"/>
			<property name="Tags" value="aecQuestLureItem"/>
			<property class="RepairItems">
				<property name="resourceScrapIron" value="0"/>
			</property>
			<drop event="Harvest" name="resourceScrapIron" count="0" tag="allHarvest"/>
			<drop event="Destroy" count="0"/>
			<drop event="Fall" name="scrapMetalPile" count="1" prob="0" stick_chance="1"/>
			<property name="SortOrder1" value="B650"/>
			<property name="SortOrder2" value="0002"/>
			<property name="Group" value="Building,advBuilding"/>
		</block>

		<block name="aecQuestAllInOneLure">
			<property name="CustomIcon" value="capChimney"/>
			<property name="DescriptionKey" value="aecQuestAllInOneLureDesc"/>
			<property name="Material" value="Mmetal_weak"/>
			<property name="MaxDamage" value="15"/>
			<property name="Shape" value="ModelEntity"/>
			<property name="Model" value="@:Entities/Buildings/capChimneyLargeSmokePrefab.prefab"/>
			<property name="DisplayType" value="blockHardened"/>
			<property name="ImposterExchange" value="imposterDontBlockCTRPole" param1="87"/>
			<property name="CustomIconTint" value="B22222"/>
			<property name="TintColor" value="B22222"/>
			<property name="WaterFlow" value="permitted"/>
			<property name="EconomicValue" value="20"/>
			<property name="Tags" value="aecQuestLureItem"/>
			<property class="RepairItems">
				<property name="resourceScrapIron" value="0"/>
			</property>
			<drop event="Harvest" name="resourceScrapIron" count="0" tag="allHarvest"/>
			<drop event="Destroy" count="0"/>
			<drop event="Fall" name="scrapMetalPile" count="1" prob="0" stick_chance="1"/>
			<property name="SortOrder1" value="B650"/>
			<property name="SortOrder2" value="0003"/>
			<property name="Group" value="Building,advBuilding"/>
		</block>

		<block name="aecQuestRelay">
			<property name="Extends" value="radioHam"/>
			<property name="DescriptionKey" value="aecQuestRelayDesc"/>
    		<property name="CustomIcon" value="radioHam"/>
			<property name="Class" value="GameEvent"/>
			<property name="ActivateEvent" value="eventAECQuestRelayActivate"/>
			<property name="CustomIconTint" value="B22222"/>
			<property name="TintColor" value="B22222"/>
			<property name="Tags" value="radio,aecQuestRelay"/>
			<property name="SortOrder1" value="B650"/>
			<property name="SortOrder2" value="0003"/>
			<property name="EconomicValue" value="250"/>
			<property name="PickupTarget" value="aecQuestRelay"/>
			<drop event="Destroy" name="aecQuestRelay" count="1" prob="1"/>
			<property name="Group" value="Building,advBuilding"/>
		</block>

		<block name="aecPortableAmmoWorkshop">
			<property name="Class" value="Workstation"/>
			<property class="Workstation">
				<property name="Modules" value="output"/>
				<property name="CraftingAreaRecipes" value="player,workbench"/>
			</property>
			<property name="UnlockedBy" value="craftingWorkstations"/>
			<property name="CreativeMode" value="Player"/>
			<property name="DescriptionKey" value="aecPortableAmmoWorkshopDesc"/>
			<property name="DisplayType" value="blockMulti"/>
			<property name="CustomIcon" value="tableSaw"/>
			<property name="WorkstationIcon" value="ui_game_symbol_table_saw"/>
			<property name="CraftIcon" value="ui_game_symbol_table_saw"/>
			<property name="CraftActionName" value="lblContextActionCraft"/>
			<property name="Stacknumber" value="1"/>
			<property name="Material" value="Miron_scrap"/>
			<property name="Shape" value="ModelEntity"/>
			<property name="Model" value="@:Entities/Crafting/table_sawPrefab.prefab"/>
			<property name="ImposterDontBlock" value="true"/>
			<property name="WaterFlow" value="permitted"/>
			<property name="Place" value="TowardsPlacerInverted"/>
			<property name="OnlySimpleRotations" value="true"/>
			<property name="Path" value="solid"/>
			<property name="IsTerrainDecoration" value="true"/>
			<property name="StabilitySupport" value="true"/>
			<property name="Weight" value="0"/>
			<property name="EconomicValue" value="0"/>
			<property name="MaxDamage" value="800"/>
			<property name="HeatMapStrength" value="5"/>
			<property name="HeatMapTime" value="5000"/>
			<property name="HeatMapFrequency" value="1000"/>
			<property name="OpenSound" value="open_workbench"/>
			<property name="CloseSound" value="close_workbench"/>
			<property name="WorkstationWindow" value="workstation_workbench"/>
			<property name="TakeDelay" value="15"/>
			<property name="SortOrder1" value="B650"/>
			<property name="SortOrder2" value="0004"/>
			<property name="Group" value="Building,TCScience,advBuilding"/>
			<property name="Tags" value="workstationSkill,twitch_workstation"/>
			<property name="FilterTags" value="MC_playerBlocks,SC_decor"/>
		</block>
	</append>
</config>
