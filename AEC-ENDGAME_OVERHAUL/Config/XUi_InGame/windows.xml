<configs>
    <!-- AEC Extreme Zombies – Custom crafting list windows with per-family category tabs -->

    <append xpath="/windows">

        <window name="windowCraftingListExtreme" width="397" height="688" controller="CraftingListInfo" panel="Left" pos="413,304" cursor_area="true" >

            <rect name="header" height="43" depth="1">
                <headerbg />
                <sprite pos="4,-5" depth="2" name="windowIcon" style="icon32px" sprite="Craft_Icon_Basics"/>
                <label style="header.name" text="basics" text_key="xuiBasics" />
            </rect>

            <rect name="content" width="397" height="650" depth="1" pos="0,-43" on_scroll="true">

                <rect depth="2" name="categorySelector" width="390" height="174" pos="3,-6">
                    <sprite name="backgroundMain" sprite="menu_empty3px" pos="-3,3" width="396" height="179" color="[black]" type="sliced" fillcenter="false" />
                    <sprite color="[mediumGrey]" type="sliced" />
                    <grid name="categories" pos="23,-21" rows="4" cols="9" width="390" height="172" cell_width="43" cell_height="43" repeat_content="true" controller="CategoryList">
                        <category_icon />
                    </grid>
                </rect>

                <rect depth="3" name="searchControls" width="390" height="44" pos="3,-182">
                    <sprite name="backgroundMain" sprite="menu_empty3px" pos="-3,3" width="396" height="49" color="[black]" type="sliced" fillcenter="false" />
                    <sprite color="[darkGrey]" type="sliced" />
                    <button depth="4" name="favorites" style="icon30px, press" pos="18,-22" sprite="server_favorite" pivot="center" sound="[paging_click]" tooltip="Favorites" tooltip_key="lblFavorites" collider_scale="1.5" />

                    <rect pos="104,0" width="200">
                        <sprite depth="4" name="searchIcon" style="icon30px" pos="0,-22" sprite="ui_game_symbol_search" pivot="center"/>
                        <textfield depth="5" name="searchInput" pos="22,-7" width="140" height="30" virtual_keyboard_prompt="vkPromptSearchTerm" search_field="true" close_group_on_tab="true" clear_button="true" />
                    </rect>

                    <rect pos="286,0" width="104" height="43">
                        <pager name="pager" pos="4,-6" contents_parent="content"/>
                    </rect>
                </rect>

                <grid name="recipes" depth="2" rows="9" cols="1" pos="3,-228" width="390" height="414" cell_width="390" cell_height="46" controller="RecipeList" repeat_content="true" arrangement="vertical" >
                    <recipe_entry name="0"/>
                </grid>
            </rect>
        </window>
        <window name="windowCraftingListHead" width="397" height="688" controller="CraftingListInfo" panel="Left" pos="413,304" cursor_area="true" >

            <rect name="header" height="43" depth="1">
                <headerbg />
                <sprite pos="4,-5" depth="2" name="windowIcon" style="icon32px" sprite="Craft_Icon_Basics"/>
                <label style="header.name" text="basics" text_key="xuiBasics" />
            </rect>

            <rect name="content" width="397" height="650" depth="1" pos="0,-43" on_scroll="true">

                <rect depth="2" name="categorySelector" width="390" height="88" pos="3,-6">
                    <sprite name="backgroundMain" sprite="menu_empty3px" pos="-3,3" width="396" height="93" color="[black]" type="sliced" fillcenter="false" />
                    <sprite color="[mediumGrey]" type="sliced" />
                    <grid name="categories" pos="23,-21" rows="2" cols="9" width="390" height="86" cell_width="43" cell_height="43" repeat_content="true" controller="CategoryList">
                        <category_icon />
                    </grid>
                </rect>

                <rect depth="3" name="searchControls" width="390" height="44" pos="3,-96">
                    <sprite name="backgroundMain" sprite="menu_empty3px" pos="-3,3" width="396" height="49" color="[black]" type="sliced" fillcenter="false" />
                    <sprite color="[darkGrey]" type="sliced" />
                    <button depth="4" name="favorites" style="icon30px, press" pos="18,-22" sprite="server_favorite" pivot="center" sound="[paging_click]" tooltip="Favorites" tooltip_key="lblFavorites" collider_scale="1.5" />

                    <rect pos="104,0" width="200">
                        <sprite depth="4" name="searchIcon" style="icon30px" pos="0,-22" sprite="ui_game_symbol_search" pivot="center"/>
                        <textfield depth="5" name="searchInput" pos="22,-7" width="140" height="30" virtual_keyboard_prompt="vkPromptSearchTerm" search_field="true" close_group_on_tab="true" clear_button="true" />
                    </rect>

                    <rect pos="286,0" width="104" height="43">
                        <pager name="pager" pos="4,-6" contents_parent="content"/>
                    </rect>
                </rect>

                <grid name="recipes" depth="2" rows="11" cols="1" pos="3,-142" width="390" height="506" cell_width="390" cell_height="46" controller="RecipeList" repeat_content="true" arrangement="vertical" >
                    <recipe_entry name="0"/>
                </grid>
            </rect>
        </window>
    </append>

</configs>